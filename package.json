{
  "name": "dhyana-meditation",
  "private": true,
  "version": "1.0.0",
  "description": "ZenGM - Guided Meditation Generator",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "predev": "tsc -p electron/tsconfig.json",
    "dev": "concurrently -k \"vite --port=3000\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:web": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build && tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "check-secrets": "node scripts/verify-no-secrets.mjs",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "standalone": "npm run dist",
    "standalone:unpacked": "npm run build && electron-builder --dir",
    "icon:generate": "node -e \"import pngToIco from 'png-to-ico'; import { writeFile } from 'node:fs/promises'; const buf = await pngToIco('public/logo.png'); await writeFile('build/icon.ico', buf); console.log('generated build/icon.ico');\""
  },
  "build": {
    "appId": "com.dhyana.meditation",
    "productName": "ZenGM - Guided Meditation Generator",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "kokoro-js": "^1.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "onnxruntime-web": "^1.24.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0",
    "webm-muxer": "^5.1.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "wait-on": "^8.0.3"
  }
}
